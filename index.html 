// ストレージ
const STORAGE_KEY = "ak_inventory";
let inventory = {};
try {
  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) inventory = JSON.parse(saved);
} catch(e) {}

function save() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(inventory));
    document.getElementById("save-status").textContent = "✓ 保存済";
  } catch(e) {
    document.getElementById("save-status").textContent = "⚠ 保存エラー";
  }
}

function getStatus(color) { return inventory[color]?.status || "×"; }
function getDate(color)   { return inventory[color]?.date || ""; }

function toggle(color) {
  const cur = getStatus(color);
  const idx = STATUSES.indexOf(cur);
  const next = STATUSES[(idx + 1) % STATUSES.length];
  if (!inventory[color]) inventory[color] = {};
  inventory[color].status = next;
  inventory[color].date = new Date().toLocaleDateString("ja-JP", {year:"numeric",month:"2-digit",day:"2-digit"});
  save();
  render();
}

