  sortMode = mode;
  document.querySelectorAll(".sort-btn").forEach(b => b.classList.remove("active"));
  el.classList.add("active");
  render();
}
window.setSort = setSort;

function matchFilter(color) {
  const s = getStatus(color);
  if (activeFilter === "すべて") return true;
  if (activeFilter === "×（在庫なし）") return s === "×";
  if (activeFilter === "1〜2本") return s === "1" || s === "2";
  if (activeFilter === "3〜5本") return s === "3" || s === "4" || s === "5";
  if (activeFilter === "5本以上") return s === "5本以上";
  return true;
}

function rowHTML(item) {
  const s   = getStatus(item.color);
  const cls = STATUS_CLASS[s];
  const dt  = getDate(item.color);
  return `<tr>
    <td class="color-num">${item.color}</td>
    <td class="col-num">${item.col}</td>
    <td><button class="status-btn ${cls}" onclick="toggle('${item.color}')">${s}</button></td>
    <td class="updated">${dt}</td>
  </tr>`;
}

function render() {
  const q = document.getElementById("search").value.trim().toLowerCase();

  let list = ALL.filter(item => {
    const matchSearch = !q || item.color.toLowerCase().includes(q);
    const matchStatus = matchFilter(item.color);
    const matchPage = activePage === "すべて" || (() => {
      const page = PAGES.find(p => p.label === activePage);
      return page ? page.cols.includes(item.col) : true;
    })();
    return matchSearch && matchStatus && matchPage;
  });

  if (sortMode === "asc") {
    list = [...list].sort((a,b) => {
      const na = parseInt(a.color), nb = parseInt(b.color);
      if (!isNaN(na) && !isNaN(nb)) return na - nb;
      if (!isNaN(na)) return -1; if (!isNaN(nb)) return 1;
      return a.color.localeCompare(b.color,"ja");
    });
  } else if (sortMode === "desc") {
    list = [...list].sort((a,b) => {
      const na = parseInt(a.color), nb = parseInt(b.color);
      if (!isNaN(na) && !isNaN(nb)) return nb - na;
      if (!isNaN(na)) return 1; if (!isNaN(nb)) return -1;
      return b.color.localeCompare(a.color,"ja");
    });
  } else if (sortMode === "status") {
    list = [...list].sort((a,b) => STATUS_ORDER[getStatus(a.color)] - STATUS_ORDER[getStatus(b.color)]);
  }

  // 集計
  let rich=0, ok=0, low=0, zero=0;
  list.forEach(item => {
    const s = getStatus(item.color);
    if (s==="5本以上") rich++;
    else if (["3","4","5"].includes(s)) ok++;
    else if (["1","2"].includes(s)) low++;
    else zero++;
  });
  document.getElementById("cnt-total").textContent = list.length;
  document.getElementById("cnt-rich").textContent  = rich;
  document.getElementById("cnt-ok").textContent    = ok;
  document.getElementById("cnt-low").textContent   = low;
  document.getElementById("cnt-zero").textContent  = zero;

  const tbody = document.getElementById("tbody");
  if (list.length === 0) {
    tbody.innerHTML = `<tr><td colspan="4" class="empty">該当する色番号がありません</td></tr>`;
    return;
  }

  // 糸帳順の場合はページごとにセクション分け（全ページ表示時のみ）
  if (sortMode === "default" && activePage === "すべて") {
    let html = "";
    for (const page of PAGES) {
      const pageItems = list.filter(item => page.cols.includes(item.col));
      if (pageItems.length === 0) continue;
      html += `<tr><td colspan="4" style="background:#2c2c2c;color:#fff;font-size:11px;font-weight:700;padding:6px 12px;letter-spacing:1px;">${page.label}</td></tr>`;
      html += pageItems.map(item => rowHTML(item)).join("");
    }
    tbody.innerHTML = html;
    return;
  }

  tbody.innerHTML = list.map(item => rowHTML(item)).join("");
}

render();
</script>
</body>
</html>
